# Template de variáveis de ambiente do ComparaSuple.
# Copie este arquivo para .env.local e preencha os valores.
# .env.local NÃO vai pro git (está no .gitignore).

# --- Supabase ---
# Painel: https://supabase.com/dashboard → projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — APENAS server-side (jobs de ingestão, route handlers).
# NUNCA exponha no cliente. Bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- Mercado Livre ---
# Tag de afiliado (do painel https://www.mercadolivre.com.br/l/afiliados-portal-do-afiliado)
ML_AFFILIATE_TAG=

# OAuth do DevCenter (opcional — só se for usar reports/escrita autenticada)
# https://developers.mercadolivre.com.br/devcenter
ML_APP_ID=
ML_CLIENT_SECRET=

# --- Cron ---
# Secret para autorizar o endpoint /api/cron/ml-ingest.
# Gere com: openssl rand -hex 32
CRON_SECRET=
